#!/usr/bin/env bash

run_repo_hook() {
  local hook_name="$1"
  shift

  local repo_root local_hook
  repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || return 0
  local_hook="${repo_root}/.githooks/${hook_name}"

  [[ -f "$local_hook" ]] || return 0

  if [[ ! -x "$local_hook" ]]; then
    echo "[${hook_name}] Skipping ${local_hook}: not executable." >&2
    return 0
  fi

  "$local_hook" "$@"
}
